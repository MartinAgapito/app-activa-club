# Plantilla de variables de entorno de Activa Club.
# Copiar como ".env" (o ".env.<entorno>") en cada app y completar con valores reales.
# NUNCA commitear un archivo .env con valores reales.

# ---- General ----
NODE_ENV=development
AWS_REGION=us-east-1

# ---- apps/web (frontend) ----
# VITE_API_BASE_URL=
# Login/refresh/logout van directo contra Cognito (US-014, ADR-0002): sin
# endpoint propio. IDs del User Pool/App Client del entorno correspondiente
# (ver `terraform output cognito_user_pool_id` / `cognito_web_client_id` en
# infrastructure/terraform/environments/<entorno>). No son secretos (el App
# Client del SPA no tiene client secret), pero igual se inyectan por entorno,
# nunca hardcodeados en el código.
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
# Opcional: por defecto se deriva del prefijo de VITE_COGNITO_USER_POOL_ID.
# VITE_COGNITO_REGION=

# ---- apps/api (backend) ----
# DYNAMODB_TABLE_NAME=
# MIGRATION_BUCKET_NAME=
# COGNITO_USER_POOL_ID=
# SES_SENDER_EMAIL=
# CULQI_PUBLIC_KEY=
# CULQI_SECRET_KEY=

# ---- Terraform / Infraestructura ----
# TF_VAR_environment=dev
